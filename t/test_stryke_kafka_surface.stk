## t/test_stryke_kafka_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Kafka

# ── Kafka.stk ──────────────────────────────────────────────
assert_ok exists &Kafka::version, "Kafka::version exists"
assert_ok exists &Kafka::ping, "Kafka::ping exists"
assert_ok exists &Kafka::cluster, "Kafka::cluster exists"
assert_ok exists &Kafka::topics, "Kafka::topics exists"
assert_ok exists &Kafka::describe, "Kafka::describe exists"
assert_ok exists &Kafka::groups, "Kafka::groups exists"
assert_ok exists &Kafka::lag, "Kafka::lag exists"
assert_ok exists &Kafka::watermarks, "Kafka::watermarks exists"
assert_ok exists &Kafka::offsets_for_times, "Kafka::offsets_for_times exists"
assert_ok exists &Kafka::produce, "Kafka::produce exists"
assert_ok exists &Kafka::produce_many, "Kafka::produce_many exists"
assert_ok exists &Kafka::consume, "Kafka::consume exists"
assert_ok exists &Kafka::consume_stream, "Kafka::consume_stream exists"
assert_ok exists &Kafka::create_topic, "Kafka::create_topic exists"
assert_ok exists &Kafka::delete_topic, "Kafka::delete_topic exists"
assert_ok exists &Kafka::create_partitions, "Kafka::create_partitions exists"
assert_ok exists &Kafka::describe_configs, "Kafka::describe_configs exists"
assert_ok exists &Kafka::alter_configs, "Kafka::alter_configs exists"
assert_ok exists &Kafka::delete_groups, "Kafka::delete_groups exists"
assert_ok exists &Kafka::delete_records, "Kafka::delete_records exists"
assert_ok exists &Kafka::describe_group, "Kafka::describe_group exists"
assert_ok exists &Kafka::committed, "Kafka::committed exists"

# ── pure helpers (no broker) ──
assert_ok exists &Kafka::valid_topic_name, "Kafka::valid_topic_name exists"
assert_ok exists &Kafka::sanitize_topic_name, "Kafka::sanitize_topic_name exists"
assert_ok exists &Kafka::is_internal_topic, "Kafka::is_internal_topic exists"
assert_ok exists &Kafka::topics_collide, "Kafka::topics_collide exists"
assert_ok exists &Kafka::parse_brokers, "Kafka::parse_brokers exists"
assert_ok exists &Kafka::build_brokers, "Kafka::build_brokers exists"
assert_ok exists &Kafka::normalize_brokers, "Kafka::normalize_brokers exists"
assert_ok exists &Kafka::partition_for_key, "Kafka::partition_for_key exists"
assert_ok exists &Kafka::partition_for_key_crc32, "Kafka::partition_for_key_crc32 exists"
assert_ok exists &Kafka::partition_for_key_fnv1a, "Kafka::partition_for_key_fnv1a exists"
assert_ok exists &Kafka::group_coordinator_partition, "Kafka::group_coordinator_partition exists"
assert_ok exists &Kafka::transaction_coordinator_partition, "Kafka::transaction_coordinator_partition exists"
assert_ok exists &Kafka::range_assignment, "Kafka::range_assignment exists"
assert_ok exists &Kafka::roundrobin_assignment, "Kafka::roundrobin_assignment exists"
assert_ok exists &Kafka::sticky_assignment, "Kafka::sticky_assignment exists"
assert_ok exists &Kafka::replica_assignment, "Kafka::replica_assignment exists"
assert_ok exists &Kafka::assignment_by_broker, "Kafka::assignment_by_broker exists"
assert_ok exists &Kafka::assignment_diff, "Kafka::assignment_diff exists"
assert_ok exists &Kafka::format_offset, "Kafka::format_offset exists"
assert_ok exists &Kafka::topic_metric_name, "Kafka::topic_metric_name exists"
assert_ok exists &Kafka::parse_topic_partition, "Kafka::parse_topic_partition exists"
assert_ok exists &Kafka::format_topic_partition, "Kafka::format_topic_partition exists"
assert_ok exists &Kafka::compression_codec, "Kafka::compression_codec exists"
assert_ok exists &Kafka::cleanup_policy, "Kafka::cleanup_policy exists"
assert_ok exists &Kafka::acks_value, "Kafka::acks_value exists"
assert_ok exists &Kafka::parse_duration_ms, "Kafka::parse_duration_ms exists"
assert_ok exists &Kafka::isr_health, "Kafka::isr_health exists"
assert_ok exists &Kafka::offset_lag, "Kafka::offset_lag exists"
assert_ok exists &Kafka::security_protocol, "Kafka::security_protocol exists"
assert_ok exists &Kafka::auto_offset_reset, "Kafka::auto_offset_reset exists"
assert_ok exists &Kafka::isolation_level, "Kafka::isolation_level exists"
assert_ok exists &Kafka::timestamp_type, "Kafka::timestamp_type exists"
assert_ok exists &Kafka::humanize_duration_ms, "Kafka::humanize_duration_ms exists"
assert_ok exists &Kafka::partition_distribution, "Kafka::partition_distribution exists"

test_run
