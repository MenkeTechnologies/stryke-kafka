# t/test_kafka.stk — round-trip tests against a live Kafka cluster.
#
# Requires the cdylib to be loaded. Install once with `s pkg install -g .`
# from the package root so stryke's FFI bridge dlopens
# lib/libstryke_kafka.{dylib,so} on `use Kafka`.

use Kafka

val $have_cdylib = eval { Kafka::version(); 1 }
unless ($have_cdylib) {
    p "1..0 # SKIP cdylib not loaded — run `s pkg install -g .` first"
    exit 0
}
unless (defined $ENV{KAFKA_BROKERS} && $ENV{KAFKA_BROKERS} ne "") {
    p "1..0 # SKIP \$KAFKA_BROKERS not set"
    exit 0
}
unless (eval { Kafka::ping() }) {
    p "1..0 # SKIP cannot reach Kafka at $ENV{KAFKA_BROKERS}"
    exit 0
}

val $topic = "stryke-kafka-test-$$"
p "1..7"
var $i = 0

# 1. cluster metadata
var $cl
eval { $cl = Kafka::cluster() }
$i++
p $@ ? "not ok $i - cluster: $@" :
       ($cl->{broker_count} > 0 ? "ok $i - cluster (#{$cl->{broker_count}} brokers)" :
        "not ok $i - cluster broker_count=0")

# 2. create topic
var $c
eval { $c = Kafka::create_topic($topic, partitions => 2, replication => 1) }
$i++
p $@ ? "not ok $i - create_topic: $@" :
       ($c->{created} ? "ok $i - create_topic" :
        "not ok $i - create_topic: $c->{error}")

# 3. topics list (find ours)
var @tlist
eval { @tlist = Kafka::topics() }
$i++
if ($@) {
    p "not ok $i - topics: $@"
} else {
    var $found = 0
    for val $t (@tlist) {
        $found = 1 if $t->{name} eq $topic
    }
    p ($found ? "ok $i - topics (found $topic)"
              : "not ok $i - topics missing $topic")
}

# 4. produce one
var $r
eval { $r = Kafka::produce($topic, "hello-stryke", key => "k1") }
$i++
p $@ ? "not ok $i - produce: $@" :
       (defined $r->{offset} ? "ok $i - produce (offset=$r->{offset})" :
        "not ok $i - produce bad shape")

# 5. produce_many
var $rm
eval {
    $rm = Kafka::produce_many(
        [ map { { topic => $topic, value => "msg-$_", key => "k$_" } } (1:5) ]
    )
}
$i++
p $@ ? "not ok $i - produce_many: $@" :
       ($rm->{sent} == 5 ? "ok $i - produce_many" :
        "not ok $i - produce_many sent=$rm->{sent}")

# 6. consume back (from beginning)
var @msgs
eval {
    @msgs = Kafka::consume(
        $topic,
        offset_reset => "earliest",
        group        => "stryke-test-$$",
        max          => 6,
        idle_ms      => 5_000,
    )
}
$i++
p $@ ? "not ok $i - consume: $@" :
       (len(@msgs) >= 6 ? "ok $i - consume (got #{len(@msgs)} msgs)" :
        "not ok $i - consume got only #{len(@msgs)} msgs")

# 7. delete topic
eval { Kafka::delete_topic($topic) }
$i++
p $@ ? "not ok $i - delete_topic: $@" : "ok $i - delete_topic"
