## t/test_kafka.stk — assertion tests for the stryke `Kafka` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_kafka.{dylib,so}` on
## `use Kafka`. Live tests fire when $KAFKA_BROKERS points at a reachable
## cluster.

use Kafka

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Kafka::version()
assert_ok $version, "Kafka::version returns truthy (cdylib loaded)"

# ── live cluster (KAFKA_BROKERS + reachable ping) ───────────────────
val $brokers = $ENV{KAFKA_BROKERS}
val $alive = defined $brokers && $brokers ne "" && eval { Kafka::ping() }

if ($alive) {
    val $topic = "stryke-kafka-test-$$"

    # 1. cluster metadata
    val $cl = Kafka::cluster()
    assert_gt scalar(@{ $cl->{brokers} }), 0, "cluster: broker_count > 0"

    # 2. create topic
    val $c = Kafka::create_topic($topic, partitions => 2, replication => 1)
    assert_ok $c->{created}, "create_topic: created=true"

    # 3. topics list (find ours)
    val @tlist = Kafka::topics()
    val $found_topic = grep { $_ eq $topic } @tlist
    assert_ok $found_topic, "topics: contains our topic"

    # 4. produce one
    val $r = Kafka::produce($topic, "hello-stryke", key => "k1")
    assert_ok defined $r->{offset}, "produce: returns offset"

    # 5. produce_many — batch of 5
    val $rm = Kafka::produce_many(
        [ map { { topic => $topic, value => "msg-$_", key => "k$_" } } (1:5) ]
    )
    assert_eq $rm, 5, "produce_many: sent=5"

    # 6. consume back (from beginning) — at least 6 messages total
    val @msgs = Kafka::consume(
        $topic,
        offset_reset => "earliest",
        group        => "stryke-test-$$",
        max          => 6,
        idle_ms      => 5_000,
    )
    assert_ge scalar(@msgs), 6, "consume: ≥6 msgs from beginning"

    # 7. delete topic
    Kafka::delete_topic($topic)
    assert_ok 1, "delete_topic completed without dying"
}

# ── pure helpers (no broker — always run) ────────────────────────────
assert_ok Kafka::valid_topic_name("orders.us-east_1")->{valid}, "valid_topic_name: accepts legal name"
val $bad = Kafka::valid_topic_name("has space")
assert_eq $bad->{valid}, 0, "valid_topic_name: rejects spaces"
assert_match qr/illegal/, $bad->{reason}, "valid_topic_name: reason explains why"

assert_eq Kafka::is_internal_topic("__consumer_offsets"), 1, "is_internal_topic: __ prefix"
assert_eq Kafka::is_internal_topic("orders"), 0,            "is_internal_topic: normal topic"

val @brokers = Kafka::parse_brokers("b1:9092, b2:9093 ,b3")
assert_eq scalar(@brokers), 3,      "parse_brokers: three brokers"
assert_eq $brokers[0]{host}, "b1",  "parse_brokers: host"
assert_eq $brokers[1]{port}, 9093,  "parse_brokers: trimmed port"

# build_brokers: inverse of parse_brokers.
assert_eq Kafka::build_brokers([ +{ host => "b1", port => 9092 }, +{ host => "b2", port => 9093 } ]), "b1:9092,b2:9093", "build_brokers: {host,port} list → bootstrap"
assert_eq Kafka::build_brokers([ +{ host => "b3" } ]), "b3", "build_brokers: portless broker is host-only"
assert_eq Kafka::build_brokers(\@brokers), "b1:9092,b2:9093,b3", "build_brokers: round-trips parse_brokers output"

# partition_for_key: default-partitioner murmur2 hash, verified against Kafka.
# toPositive(murmur2("foobar")) % 10 = 6; hash is the signed murmur2 value.
val $pk = Kafka::partition_for_key("foobar", 10)
assert_eq $pk->{hash},      -790332482, "partition_for_key: murmur2 matches Kafka reference"
assert_eq $pk->{partition}, 6,          "partition_for_key: toPositive % partitions"
# Same key + same partition count is deterministic and in range.
assert_eq Kafka::partition_for_key("foobar", 10)->{partition}, 6, "partition_for_key: deterministic"
assert_lt Kafka::partition_for_key("user-42", 4)->{partition}, 4, "partition_for_key: result < partition count"
assert_dies fn { Kafka::partition_for_key("x", 0) }, "partition_for_key: rejects zero partitions"

# partition_for_key_crc32: librdkafka `consistent` partitioner (crc32 % partitions).
# crc32("foobar") = 0x9EF61F95 = 2666930069; 2666930069 % 10 = 9.
val $ck = Kafka::partition_for_key_crc32("foobar", 10)
assert_eq $ck->{crc32},     2666930069, "partition_for_key_crc32: crc32 matches zlib reference"
assert_eq $ck->{partition}, 9,          "partition_for_key_crc32: crc32 % partitions"
# The two partitioners disagree for the same key/topology (murmur2 → 6, crc32 → 9).
assert_ne Kafka::partition_for_key("foobar", 10)->{partition}, $ck->{partition}, "partition_for_key_crc32: differs from murmur2 partitioner"
assert_lt Kafka::partition_for_key_crc32("user-42", 4)->{partition}, 4, "partition_for_key_crc32: result < partition count"
assert_dies fn { Kafka::partition_for_key_crc32("x", 0) }, "partition_for_key_crc32: rejects zero partitions"

assert_eq Kafka::format_offset(-1)->{name}, "latest",     "format_offset: -1 → latest"
assert_eq Kafka::format_offset(-2)->{name}, "earliest",   "format_offset: -2 → earliest"
assert_eq Kafka::format_offset("earliest")->{offset}, -2, "format_offset: earliest → -2"
assert_dies fn { Kafka::format_offset("nonsense") }, "format_offset: rejects unknown name"

test_run
