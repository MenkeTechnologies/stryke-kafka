## t/test_kafka.stk — assertion tests for the stryke `Kafka` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_kafka.{dylib,so}` on
## `use Kafka`. Live tests fire when $KAFKA_BROKERS points at a reachable
## cluster.

use Kafka

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Kafka::version()
assert_ok $version, "Kafka::version returns truthy (cdylib loaded)"

# ── live cluster (KAFKA_BROKERS + reachable ping) ───────────────────
val $brokers = $ENV{KAFKA_BROKERS}
val $alive = defined $brokers && $brokers ne "" && eval { Kafka::ping() }

if ($alive) {
    val $topic = "stryke-kafka-test-$$"

    # 1. cluster metadata
    val $cl = Kafka::cluster()
    assert_gt scalar(@{ $cl->{brokers} }), 0, "cluster: broker_count > 0"

    # 2. create topic
    val $c = Kafka::create_topic($topic, partitions => 2, replication => 1)
    assert_ok $c->{created}, "create_topic: created=true"

    # 3. topics list (find ours)
    val @tlist = Kafka::topics()
    val $found_topic = grep { $_ eq $topic } @tlist
    assert_ok $found_topic, "topics: contains our topic"

    # 4. produce one
    val $r = Kafka::produce($topic, "hello-stryke", key => "k1")
    assert_ok defined $r->{offset}, "produce: returns offset"

    # 5. produce_many — batch of 5
    val $rm = Kafka::produce_many(
        [ map { { topic => $topic, value => "msg-$_", key => "k$_" } } (1:5) ]
    )
    assert_eq $rm, 5, "produce_many: sent=5"

    # 6. consume back (from beginning) — at least 6 messages total
    val @msgs = Kafka::consume(
        $topic,
        offset_reset => "earliest",
        group        => "stryke-test-$$",
        max          => 6,
        idle_ms      => 5_000,
    )
    assert_ge scalar(@msgs), 6, "consume: ≥6 msgs from beginning"

    # 7. delete topic
    Kafka::delete_topic($topic)
    assert_ok 1, "delete_topic completed without dying"
}

# ── pure helpers (no broker — always run) ────────────────────────────
assert_ok Kafka::valid_topic_name("orders.us-east_1")->{valid}, "valid_topic_name: accepts legal name"
val $bad = Kafka::valid_topic_name("has space")
assert_eq $bad->{valid}, 0, "valid_topic_name: rejects spaces"
assert_match qr/illegal/, $bad->{reason}, "valid_topic_name: reason explains why"

# sanitize_topic_name: coerce arbitrary input into a valid topic name.
assert_eq Kafka::sanitize_topic_name("orders.us-east_1")->{sanitized}, "orders.us-east_1", "sanitize_topic_name: legal name unchanged"
assert_eq Kafka::sanitize_topic_name("orders.us-east_1")->{changed},   0,                  "sanitize_topic_name: changed flag false when legal"
assert_eq Kafka::sanitize_topic_name("my topic!")->{sanitized}, "my_topic_", "sanitize_topic_name: illegal chars become _"
assert_eq Kafka::sanitize_topic_name("..")->{sanitized},        "_",         "sanitize_topic_name: reserved name falls back to replacement"
assert_eq Kafka::sanitize_topic_name("a b", "-")->{sanitized},  "a-b",       "sanitize_topic_name: custom replacement"
# The sanitized output always validates.
assert_ok Kafka::valid_topic_name(Kafka::sanitize_topic_name("a/b:c@d")->{sanitized})->{valid}, "sanitize_topic_name: output passes valid_topic_name"

assert_eq Kafka::is_internal_topic("__consumer_offsets"), 1, "is_internal_topic: __ prefix"
assert_eq Kafka::is_internal_topic("orders"), 0,            "is_internal_topic: normal topic"

# topics_collide: metric-namespace collision (. unifies to _).
assert_eq Kafka::topics_collide("my.topic", "my_topic"), 1, "topics_collide: my.topic vs my_topic collide"
assert_eq Kafka::topics_collide("a.b.c", "a_b_c"),       1, "topics_collide: multiple periods unify"
assert_eq Kafka::topics_collide("orders", "events"),     0, "topics_collide: distinct names do not collide"

val @brokers = Kafka::parse_brokers("b1:9092, b2:9093 ,b3")
assert_eq scalar(@brokers), 3,      "parse_brokers: three brokers"
assert_eq $brokers[0]{host}, "b1",  "parse_brokers: host"
assert_eq $brokers[1]{port}, 9093,  "parse_brokers: trimmed port"

# build_brokers: inverse of parse_brokers.
assert_eq Kafka::build_brokers([ +{ host => "b1", port => 9092 }, +{ host => "b2", port => 9093 } ]), "b1:9092,b2:9093", "build_brokers: {host,port} list → bootstrap"
assert_eq Kafka::build_brokers([ +{ host => "b3" } ]), "b3", "build_brokers: portless broker is host-only"
assert_eq Kafka::build_brokers(\@brokers), "b1:9092,b2:9093,b3", "build_brokers: round-trips parse_brokers output"

# normalize_brokers: fill default port, trim, dedupe.
assert_eq Kafka::normalize_brokers("h1, h2:9093 ,h3"), "h1:9092,h2:9093,h3:9092", "normalize_brokers: fills :9092, trims"
assert_eq Kafka::normalize_brokers("h1:9092,h1,h2"), "h1:9092,h2:9092", "normalize_brokers: dedupes after port-filling"
assert_eq Kafka::normalize_brokers("h1,h2", default_port => 19092), "h1:19092,h2:19092", "normalize_brokers: custom default port"
assert_dies fn { Kafka::normalize_brokers(" , ") }, "normalize_brokers: rejects an empty list"

# partition_for_key: default-partitioner murmur2 hash, verified against Kafka.
# toPositive(murmur2("foobar")) % 10 = 6; hash is the signed murmur2 value.
val $pk = Kafka::partition_for_key("foobar", 10)
assert_eq $pk->{hash},      -790332482, "partition_for_key: murmur2 matches Kafka reference"
assert_eq $pk->{partition}, 6,          "partition_for_key: toPositive % partitions"
# Same key + same partition count is deterministic and in range.
assert_eq Kafka::partition_for_key("foobar", 10)->{partition}, 6, "partition_for_key: deterministic"
assert_lt Kafka::partition_for_key("user-42", 4)->{partition}, 4, "partition_for_key: result < partition count"
assert_dies fn { Kafka::partition_for_key("x", 0) }, "partition_for_key: rejects zero partitions"

# partition_for_key_crc32: librdkafka `consistent` partitioner (crc32 % partitions).
# crc32("foobar") = 0x9EF61F95 = 2666930069; 2666930069 % 10 = 9.
val $ck = Kafka::partition_for_key_crc32("foobar", 10)
assert_eq $ck->{crc32},     2666930069, "partition_for_key_crc32: crc32 matches zlib reference"
assert_eq $ck->{partition}, 9,          "partition_for_key_crc32: crc32 % partitions"
# The two partitioners disagree for the same key/topology (murmur2 → 6, crc32 → 9).
assert_ne Kafka::partition_for_key("foobar", 10)->{partition}, $ck->{partition}, "partition_for_key_crc32: differs from murmur2 partitioner"
assert_lt Kafka::partition_for_key_crc32("user-42", 4)->{partition}, 4, "partition_for_key_crc32: result < partition count"
assert_dies fn { Kafka::partition_for_key_crc32("x", 0) }, "partition_for_key_crc32: rejects zero partitions"

# partition_for_key_fnv1a: librdkafka `fnv1a` partitioner (fnv1a % partitions).
val $fk = Kafka::partition_for_key_fnv1a("foobar", 10)
assert_eq $fk->{fnv1a},     3214735720, "partition_for_key_fnv1a: 32-bit FNV-1a of 'foobar' (0xbf9cf968)"
assert_eq $fk->{partition}, 0,          "partition_for_key_fnv1a: fnv1a % partitions"
assert_lt Kafka::partition_for_key_fnv1a("user-42", 4)->{partition}, 4, "partition_for_key_fnv1a: result < partition count"
assert_dies fn { Kafka::partition_for_key_fnv1a("x", 0) }, "partition_for_key_fnv1a: rejects zero partitions"

# group_coordinator_partition: __consumer_offsets partition = abs(hashCode) % 50.
# Verified vs a JVM hashCode oracle: "abc"=96354→part 4, "test"=3556498→part 48.
assert_eq Kafka::group_coordinator_partition("abc")->{partition}, 4,  "group_coordinator_partition: abc → 4 of 50"
assert_eq Kafka::group_coordinator_partition("test")->{partition}, 48, "group_coordinator_partition: test → 48 of 50"
assert_eq Kafka::group_coordinator_partition("abc")->{hash}, 96354,   "group_coordinator_partition: raw JVM hashCode"
assert_eq Kafka::group_coordinator_partition("my-consumer-group")->{partition}, 13, "group_coordinator_partition: realistic group id"
assert_lt Kafka::group_coordinator_partition("g", 16)->{partition}, 16, "group_coordinator_partition: honors explicit partition count"
assert_dies fn { Kafka::group_coordinator_partition("g", 0) }, "group_coordinator_partition: rejects zero partitions"

# transaction_coordinator_partition: __transaction_state partition (same formula).
assert_eq Kafka::transaction_coordinator_partition("abc")->{partition}, 4, "transaction_coordinator_partition: abc → 4 of 50 (same formula)"
assert_eq Kafka::transaction_coordinator_partition("abc")->{hash}, 96354, "transaction_coordinator_partition: raw JVM hashCode"
# Agrees with group_coordinator_partition for any shared id.
assert_eq Kafka::transaction_coordinator_partition("orders-producer-1")->{partition}, Kafka::group_coordinator_partition("orders-producer-1")->{partition}, "transaction_coordinator_partition: agrees with group op"
assert_lt Kafka::transaction_coordinator_partition("t", 16)->{partition}, 16, "transaction_coordinator_partition: honors explicit partition count"
assert_dies fn { Kafka::transaction_coordinator_partition("t", 0) }, "transaction_coordinator_partition: rejects zero partitions"

# range_assignment: Kafka default RangeAssignor for one topic.
val $ra = Kafka::range_assignment(7, "c0", "c1", "c2")
assert_eq join(",", @{ $ra->{assignment}{c0} }), "0,1,2", "range_assignment: first member absorbs the remainder"
assert_eq join(",", @{ $ra->{assignment}{c1} }), "3,4",   "range_assignment: second member block"
assert_eq join(",", @{ $ra->{assignment}{c2} }), "5,6",   "range_assignment: third member block"
val $sp = Kafka::range_assignment(2, "x", "y", "z")
assert_eq scalar(@{ $sp->{assignment}{z} }), 0, "range_assignment: surplus consumer gets nothing"
assert_dies fn { Kafka::range_assignment(0, "a") }, "range_assignment: rejects zero partitions"

# roundrobin_assignment: Kafka RoundRobinAssignor for one topic (interleaved).
val $rr = Kafka::roundrobin_assignment(7, "c0", "c1", "c2")
assert_eq join(",", @{ $rr->{assignment}{c0} }), "0,3,6", "roundrobin_assignment: c0 gets every third partition"
assert_eq join(",", @{ $rr->{assignment}{c1} }), "1,4",   "roundrobin_assignment: c1 interleaved"
assert_eq join(",", @{ $rr->{assignment}{c2} }), "2,5",   "roundrobin_assignment: c2 interleaved"
val $rrs = Kafka::roundrobin_assignment(2, "x", "y", "z")
assert_eq scalar(@{ $rrs->{assignment}{z} }), 0, "roundrobin_assignment: surplus consumer gets nothing"
assert_dies fn { Kafka::roundrobin_assignment(0, "a") }, "roundrobin_assignment: rejects zero partitions"

# sticky_assignment: StickyAssignor — balanced, movement-minimizing.
val $sk = Kafka::sticky_assignment(7, ["c0", "c1", "c2"])
assert_eq join(",", @{ $sk->{assignment}{c0} }), "0,1,2", "sticky_assignment: no-previous balanced fill (ceil to first id)"
assert_eq join(",", @{ $sk->{assignment}{c2} }), "5,6",   "sticky_assignment: no-previous tail member"
# A consumer leaves: survivors keep what they own; only the departed member's partitions move.
val $sl = Kafka::sticky_assignment(7, ["c0", "c2"], { c0 => [0, 1, 2], c1 => [3, 4], c2 => [5, 6] })
assert_eq join(",", @{ $sl->{assignment}{c0} }), "0,1,2,3", "sticky_assignment: survivor keeps its partitions and absorbs an orphan"
assert_eq join(",", @{ $sl->{assignment}{c2} }), "4,5,6",   "sticky_assignment: second survivor absorbs the other orphan"
# A consumer joins: incumbents shed only what balance requires.
val $sj = Kafka::sticky_assignment(7, ["c0", "c1", "c2"], { c0 => [0, 1, 2, 3], c1 => [4, 5, 6] })
assert_eq join(",", @{ $sj->{assignment}{c2} }), "3,6", "sticky_assignment: new consumer gets the shed partitions"
assert_dies fn { Kafka::sticky_assignment(0, ["a"]) }, "sticky_assignment: rejects zero partitions"

# replica_assignment: Kafka's default rack-unaware partition→broker placement.
val $rep = Kafka::replica_assignment(10, 3, [0, 1, 2, 3, 4])
assert_eq join(",", @{ $rep->{assignment}[0]{replicas} }), "0,1,2", "replica_assignment: partition 0 → brokers 0,1,2"
assert_eq join(",", @{ $rep->{assignment}[3]{replicas} }), "3,4,0", "replica_assignment: leader wraps around the broker list"
assert_eq join(",", @{ $rep->{assignment}[5]{replicas} }), "0,2,3", "replica_assignment: follower shift bumps after nBrokers partitions"
assert_eq $rep->{assignment}[9]{partition}, 9, "replica_assignment: partition ids reported"
assert_dies fn { Kafka::replica_assignment(3, 4, [0, 1, 2]) }, "replica_assignment: rejects RF larger than broker count"
assert_dies fn { Kafka::replica_assignment(0, 1, [0]) },       "replica_assignment: rejects zero partitions"

# assignment_by_broker: invert a partition→broker assignment to a per-broker view.
val $by = Kafka::assignment_by_broker([ +{ partition => 0, replicas => [0, 1] }, +{ partition => 1, replicas => [1, 2] }, +{ partition => 2, replicas => [2, 0] } ])
assert_eq scalar(@{ $by->{brokers} }), 3,                       "assignment_by_broker: three brokers"
assert_eq $by->{brokers}[0]{broker}, 0,                         "assignment_by_broker: sorted by broker id"
assert_eq join(",", @{ $by->{brokers}[0]{leader} }), "0",       "assignment_by_broker: broker 0 leads partition 0"
assert_eq join(",", @{ $by->{brokers}[0]{replicas} }), "0,2",   "assignment_by_broker: broker 0 replicates partitions 0 and 2"
assert_eq $by->{brokers}[0]{leader_count}, 1,                   "assignment_by_broker: leader count"
# Round-trips replica_assignment.
val $rt = Kafka::assignment_by_broker(Kafka::replica_assignment(10, 3, [0, 1, 2, 3, 4])->{assignment})
assert_eq scalar(@{ $rt->{brokers} }), 5,                       "assignment_by_broker: all 5 brokers host partitions"
assert_dies fn { Kafka::assignment_by_broker("nope") }, "assignment_by_broker: rejects a non-array assignment"
# assignment_diff: what moves between two assignments (rebalance planning).
val $ad = Kafka::assignment_diff({ c0 => [0, 1, 2, 3], c1 => [4, 5, 6] }, { c0 => [0, 1, 2], c1 => [4, 5], c2 => [3, 6] })
assert_eq join(",", @{ $ad->{revoked}{c0} }),  "3", "assignment_diff: c0 gives up partition 3"
assert_eq join(",", @{ $ad->{revoked}{c1} }),  "6", "assignment_diff: c1 gives up partition 6"
assert_eq join(",", @{ $ad->{assigned}{c2} }), "3,6", "assignment_diff: new consumer c2 gains the shed partitions"
assert_eq $ad->{moved}, 2, "assignment_diff: two partitions changed owner"
val $noop = Kafka::assignment_diff({ c0 => [0, 1] }, { c0 => [0, 1] })
assert_eq $noop->{moved}, 0, "assignment_diff: identical assignments move nothing"

assert_eq Kafka::format_offset(-1)->{name}, "latest",     "format_offset: -1 → latest"
assert_eq Kafka::format_offset(-2)->{name}, "earliest",   "format_offset: -2 → earliest"
assert_eq Kafka::format_offset("earliest")->{offset}, -2, "format_offset: earliest → -2"
assert_dies fn { Kafka::format_offset("nonsense") }, "format_offset: rejects unknown name"

# topic_metric_name: single-name metric mangling (. → _).
assert_eq Kafka::topic_metric_name("my.topic")->{metric_name}, "my_topic", "topic_metric_name: periods unify"
assert_eq Kafka::topic_metric_name("orders")->{has_collision_chars}, 0,    "topic_metric_name: plain name has no collision chars"

# parse_topic_partition / format_topic_partition: round-trip.
val $tp = Kafka::parse_topic_partition("my-topic.name-7")
assert_eq $tp->{topic}, "my-topic.name", "parse_topic_partition: final - splits, topic keeps - and ."
assert_eq $tp->{partition}, 7,           "parse_topic_partition: partition suffix"
assert_eq Kafka::parse_topic_partition("orders:12")->{partition}, 12, "parse_topic_partition: : separator"
assert_eq Kafka::format_topic_partition("my-topic.name", 7), "my-topic.name-7", "format_topic_partition: inverse"
assert_eq Kafka::format_topic_partition("t", 3, ":"), "t:3", "format_topic_partition: custom separator"
assert_dies fn { Kafka::parse_topic_partition("nopartition") }, "parse_topic_partition: rejects a bare topic"

# compression_codec: validate + canonicalize.
assert_eq Kafka::compression_codec("ZSTD")->{canonical}, "zstd", "compression_codec: case-insensitive canonical"
assert_eq Kafka::compression_codec("brotli")->{valid}, 0,        "compression_codec: rejects unknown codec"

# cleanup_policy: validate + stable order.
assert_eq Kafka::cleanup_policy("delete, compact")->{canonical}, "compact,delete", "cleanup_policy: stable order"
assert_eq Kafka::cleanup_policy("archive")->{valid}, 0,                             "cleanup_policy: rejects unknown policy"

# acks_value: canonicalize to numeric.
assert_eq Kafka::acks_value("all")->{acks}, -1, "acks_value: all → -1"
assert_eq Kafka::acks_value("all")->{all},  1,  "acks_value: all flags full-ISR durability"
assert_eq Kafka::acks_value(1)->{acks},     1,  "acks_value: numeric passes through"
assert_dies fn { Kafka::acks_value("quorum") }, "acks_value: rejects unknown value"

# parse_duration_ms: human duration → millis.
assert_eq Kafka::parse_duration_ms("7d"),   604800000, "parse_duration_ms: 7 days"
assert_eq Kafka::parse_duration_ms("500ms"), 500,      "parse_duration_ms: bare ms"
assert_eq Kafka::parse_duration_ms("-1"),    -1,       "parse_duration_ms: infinite sentinel"
assert_dies fn { Kafka::parse_duration_ms("5y") }, "parse_duration_ms: rejects unknown unit"

# isr_health: replication health from replicas/isr/min_isr.
val $h = Kafka::isr_health([0, 1, 2], [0, 1, 2], 2)
assert_eq $h->{healthy}, 1, "isr_health: fully in-sync is healthy"
val $u = Kafka::isr_health([0, 1, 2], [0], 2)
assert_eq $u->{under_min_isr}, 1, "isr_health: below min.insync.replicas"
assert_dies fn { Kafka::isr_health([0], [0, 1]) }, "isr_health: rejects ISR larger than replicas"

# offset_lag: offline lag from committed + high watermark.
val $ol = Kafka::offset_lag([ +{ partition => 0, committed => 100, high => 150 }, +{ partition => 1, committed => undef, high => 25 } ])
assert_eq $ol->{partitions}[0]{lag}, 50, "offset_lag: high - committed"
assert_eq $ol->{partitions}[1]{lag}, 25, "offset_lag: no commit → full backlog"
assert_eq $ol->{total_lag}, 75,          "offset_lag: total across partitions"

# security_protocol: validate + uppercase canonical.
assert_eq Kafka::security_protocol("sasl_ssl")->{canonical}, "SASL_SSL", "security_protocol: lowercase canonicalized up"
assert_eq Kafka::security_protocol("kerberos")->{valid}, 0,             "security_protocol: rejects unknown protocol"

# auto_offset_reset: keywords + by_duration form.
assert_eq Kafka::auto_offset_reset("EARLIEST")->{canonical}, "earliest",            "auto_offset_reset: keyword canonical"
assert_eq Kafka::auto_offset_reset("by_duration:7d")->{canonical}, "by_duration:604800000", "auto_offset_reset: by_duration re-emits millis"
assert_eq Kafka::auto_offset_reset("smallest")->{valid}, 0,                          "auto_offset_reset: rejects unknown keyword"

# isolation_level: read_committed flag.
assert_eq Kafka::isolation_level("read_committed")->{read_committed}, 1, "isolation_level: read_committed flag set"
assert_eq Kafka::isolation_level("read_uncommitted")->{read_committed}, 0, "isolation_level: read_uncommitted flag clear"

# timestamp_type: mixed-case canonical.
assert_eq Kafka::timestamp_type("logappendtime")->{canonical}, "LogAppendTime", "timestamp_type: canonical spelling"
assert_eq Kafka::timestamp_type("wallclock")->{valid}, 0,                       "timestamp_type: rejects unknown type"

# humanize_duration_ms: inverse of parse_duration_ms.
assert_eq Kafka::humanize_duration_ms(604800000)->{human}, "1w",       "humanize_duration_ms: a week is the largest exact unit"
assert_eq Kafka::humanize_duration_ms(259200000)->{human}, "3d",       "humanize_duration_ms: 3 days (no exact week) falls back to days"
assert_eq Kafka::humanize_duration_ms(-1)->{human}, "infinite",        "humanize_duration_ms: infinite sentinel"
assert_eq Kafka::parse_duration_ms(Kafka::humanize_duration_ms(90000)->{human}), 90000, "humanize_duration_ms: round-trips through parse_duration_ms"

# partition_distribution: key skew across partitions.
val $pd = Kafka::partition_distribution(["a", "b", "c", "a", "a"], 4)
assert_eq $pd->{total}, 5, "partition_distribution: total counts every key"
assert_eq scalar(@{ $pd->{counts} }), 4, "partition_distribution: one count slot per partition"
assert_eq $pd->{spread}, $pd->{max} - $pd->{min}, "partition_distribution: spread = max - min"

test_run
